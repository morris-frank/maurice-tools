# Brewfile - Homebrew dependencies for maurice-tools
# Usage: brew bundle

# Core dependencies
tap "homebrew/bundle"

# Python runtime
brew "python@3.12"

# Python package manager (faster than pip)
brew "uv"

# Audio/video processing
brew "ffmpeg"

# JSON processor
brew "jq"

# Optional: useful for development
# brew "shellcheck"  # Lint shell scripts
