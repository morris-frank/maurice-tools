#!/usr/bin/env bash
set -euo pipefail

# secrets-set - Store a secret in macOS Keychain
# Usage: secrets-set <provider>
#   provider: openai, deepgram, anthropic
#   Reads API key from stdin or prompts interactively

# Determine installation paths
if [[ -n "${MAURICE_ROOT:-}" ]]; then
    readonly LIBEXEC="$MAURICE_ROOT/libexec"
else
    readonly BIN="${0%/*}"
    readonly LIBEXEC="${BIN%/*}/libexec"
fi

# Source shared helpers
# shellcheck source=./shared_helpers.sh
source "$LIBEXEC/shared_helpers.sh"

check_macos

# Validate arguments
if [[ $# -ne 1 ]]; then
    error "Usage: $(basename "$0") <provider>"
    error "  provider: openai, deepgram, anthropic"
    exit 1
fi

PROVIDER="$1"

# Validate provider
case "$PROVIDER" in
    openai|deepgram|anthropic)
        ;;
    *)
        error "Unknown provider: $PROVIDER"
        error "Supported providers: openai, deepgram, anthropic"
        exit 1
        ;;
esac

# Get API key
API_KEY=""

# Check if we're being piped input
if [[ ! -t 0 ]]; then
    # Read from stdin
    read -r API_KEY
fi

# If no piped input, prompt interactively
if [[ -z "$API_KEY" ]]; then
    echo -n "Enter your $PROVIDER API key: "
    read -s API_KEY
    echo
fi

# Validate API key is not empty
if [[ -z "$API_KEY" ]]; then
    error "API key cannot be empty"
    exit 1
fi

# Construct service name following convention
SERVICE="maurice.${PROVIDER}.api_key"
ACCOUNT=$(get_macos_username)

# Check if secret already exists and delete it
if secret_exists "$SERVICE"; then
    info "Updating existing $PROVIDER API key..."
    security delete-generic-password -s "$SERVICE" -a "$ACCOUNT" &>/dev/null || true
else
    info "Storing $PROVIDER API key..."
fi

# Add to Keychain
# -s: service name
# -a: account name
# -w: password (from stdin or variable)
# -U: Update if exists (but we delete first for clean slate)
# -T: Allow access from specified applications (empty = ask every time)
if echo "$API_KEY" | security add-generic-password \
    -s "$SERVICE" \
    -a "$ACCOUNT" \
    -w \
    -U \
    2>/dev/null; then
    success "$PROVIDER API key stored securely in macOS Keychain"
else
    error "Failed to store API key"
    error "You may need to grant access or unlock your Keychain"
    exit 1
fi

# Clear sensitive data
unset API_KEY
