#!/usr/bin/env bash
set -euo pipefail

# secrets-get - Retrieve a secret from macOS Keychain
# Usage: secrets-get <provider>
#   provider: openai, deepgram, anthropic
# Returns: The API key on stdout

# Determine installation paths
if [[ -n "${MAURICE_ROOT:-}" ]]; then
    readonly LIBEXEC="$MAURICE_ROOT/libexec"
else
    readonly BIN="${0%/*}"
    readonly LIBEXEC="${BIN%/*}/libexec"
fi

# Source shared helpers
# shellcheck source=./shared_helpers.sh
source "$LIBEXEC/shared_helpers.sh"

# Validate arguments
if [[ $# -ne 1 ]]; then
    error "Usage: $(basename "$0") <provider>"
    error "  provider: openai, deepgram, anthropic"
    exit 1
fi

PROVIDER="$1"

# Validate provider
case "$PROVIDER" in
    openai|deepgram|anthropic)
        ;;
    *)
        error "Unknown provider: $PROVIDER"
        error "Supported providers: openai, deepgram, anthropic"
        exit 1
        ;;
esac

# Construct service name
SERVICE="maurice.${PROVIDER}.api_key"
ACCOUNT=$(get_macos_username)

# Retrieve from Keychain
if ! secret_exists "$SERVICE"; then
    error "No API key found for $PROVIDER"
    error "Set it with: maurice secret set $PROVIDER"
    exit 1
fi

# Get the password from Keychain
# security find-generic-password outputs to stderr, password to stdout
if ! security find-generic-password -s "$SERVICE" -a "$ACCOUNT" -w 2>/dev/null; then
    error "Failed to retrieve API key for $PROVIDER"
    exit 1
fi
